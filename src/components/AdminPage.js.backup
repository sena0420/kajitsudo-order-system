      setTimeout(() => {
        setUploadResult(mockResult);
        setUploadDialogOpen(false);
        setSelectedFile(null);
        setPreviewData([]);
        setShowPreview(false);
        setProcessing(false);
      }, 2000); // 2秒の処理時間をシミュレート
      
    } catch (error) {
      console.error('アップロードエラー:', error);
      setUploadResult({
        success: 0,
        total: previewData.length,
        errors: [{ row: 0, error: error.message }]
