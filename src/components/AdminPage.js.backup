    } catch (error) {
      console.error('納品不可日の保存エラー:', error);
      alert('保存に失敗しました');
    }
  };

  return (
    <Box>
      <Typography variant="h4" sx={{ mb: 3, display: 'flex', alignItems: 'center' }}>
        <Chip 
          label="管理者" 
          color="warning" 
